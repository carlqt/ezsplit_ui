{
  "name": "ez-ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "tsc && vite build",
    "lint": "eslint . --ext ts,tsx --ignore-pattern 'src/__generated__/*' --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "codegen": "graphql-codegen --config codegen.ts",
    "db:schema:apply": "docker compose run --rm dev-cli atlas schema apply --env local --auto-approve",
    "db:seed:run": "docker compose run --rm dev-cli go run cmd/seed/main.go",
    "db:setup": "pnpm db:schema:apply && pnpm db:seed:run"
  },
  "dependencies": {
    "@apollo/client": "^3.10.5",
    "@graphql-typed-document-node/core": "^3.2.0",
    "@mantine/core": "^7.10.2",
    "@mantine/hooks": "^7.10.2",
    "@tabler/icons-react": "^3.6.0",
    "@tanstack/react-router": "^1.38.1",
    "@tanstack/router-cli": "^1.37.0",
    "@tanstack/router-devtools": "^1.38.1",
    "@tanstack/router-vite-plugin": "^1.39.1",
    "graphql": "^16.8.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "5.0.2",
    "@graphql-codegen/client-preset": "4.2.5",
    "@graphql-codegen/introspection": "4.0.3",
    "@graphql-codegen/typescript": "^4.0.7",
    "@graphql-codegen/typescript-resolvers": "^4.1.0",
    "@parcel/watcher": "^2.4.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.13.1",
    "@typescript-eslint/parser": "^7.13.1",
    "@vitejs/plugin-react-swc": "^3.7.0",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.7",
    "postcss": "^8.4.38",
    "typescript": "^5.4.5",
    "vite": "^5.3.1",
    "vite-tsconfig-paths": "^4.3.2"
  }
}
